datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Auth models and enums

enum UserRole {
  User
  Moderator
  Admin
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(User)
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  File File[]
  PendingFile PendingFile[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// File model and enums

enum FileStatus {
  Pending
  Approved
  Rejected
}

enum FileType {
  Lecture
  DW_Worksheet
  PW_Worksheet
  Interrogation
  Exam
  PW_Exam
}

enum AcademicLevel {
  L1
  L2
  L3
  M1
  M2
  D1
  D2
  D3
  ING1
  ING2
  ING3
  ING4
  ING5
}

enum Semester {
  S1
  S2
}

model PendingFile {
  id      String @id @default(cuid())
  driveId String @unique

  type FileType

  academicLevel AcademicLevel
  academicYear  Int
  semester      Semester
  section       String
  group         String?

  majorName     String
  moduleName    String
  professorFullName String

  status     FileStatus @default(Pending)

  uploadedAt      DateTime @default(now())

  uploadedBy User @relation(fields: [uploadedByEmail], references: [email])
  uploadedByEmail String
}

model File {
  id      String @id @default(cuid())
  driveId String @unique

  type FileType

  academicLevel AcademicLevel
  academicYear  Int
  semester      Semester
  section       String
  group         String?

  major     Major  @relation(fields: [majorName], references: [name])
  majorName String

  module     Module @relation(fields: [moduleName], references: [name])
  moduleName String

  professor         Professor @relation(fields: [professorFullName], references: [fullName])
  professorFullName String

  uploadedAt DateTime   @default(now())

  uploadedBy      User   @relation(fields: [uploadedByEmail], references: [email])
  uploadedByEmail String
}

model Professor {
  id       String @id @default(cuid())
  fullName String @unique

  File File[]
}

model Module {
  id  String @id @default(cuid())
  name String @unique

  File File[]
}

model Major {
  id   String @id @default(cuid())
  name String @unique

  File File[]
}
