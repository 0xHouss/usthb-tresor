// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  MODERATOR
  DELEGATE
  ADMIN
}

enum ResourceType {
  LECTURE
  DW_WORKSHEET
  PW_WORKSHEET
  INTERROGATION
  EXAM
  PW_EXAM
}

enum AcademicLevel {
  L1
  L2
  L3
  M1
  M2
  D1
  D2
  D3
  ING1
  ING2
  ING3
  ING4
  ING5
}

enum Semester {
  S1
  S2
}

enum ResourceStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  email     String   @id
  name      String?
  avatar    String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources Resource[]
}

model Major {
  id        String     @id @default(cuid())
  name      String     @unique
  modules   Module[]
  resources Resource[]
}

model Module {
  id        String     @id @default(cuid())
  name      String
  majorId   String
  major     Major      @relation(fields: [majorId], references: [id])
  resources Resource[]

  @@unique([name, majorId])
}

model Professor {
  id        String     @id @default(cuid())
  fullName  String     @unique
  resources Resource[]
}

model Resource {
  id       String         @id @default(cuid())
  title    String?
  type     ResourceType
  level    AcademicLevel
  semester Semester
  section  String?
  group    String?
  year     Int
  chapter  String?
  status   ResourceStatus @default(PENDING)

  majorId          String
  major            Major      @relation(fields: [majorId], references: [id])
  moduleId         String
  module           Module     @relation(fields: [moduleId], references: [id])
  professorId      String?
  professor        Professor? @relation(fields: [professorId], references: [id])
  contributorEmail String
  contributor      User       @relation(fields: [contributorEmail], references: [email])

  driveFileId String
  fileName    String
  mimeType    String?
  size        Int?

  reviewedByEmail String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([majorId, moduleId, type, level, semester, year])
}
