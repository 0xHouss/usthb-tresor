generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = "file:./dev.db"
}

enum UserRole {
    USER
    DELEGATE
    ADMIN
}

model User {
    email     String   @id
    name      String?
    avatar    String?
    role      UserRole @default(USER)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    files File[]
}

model File {
    id           String   @id
    type         String
    speciality   String
    academicYear String
    section      String
    group        String?
    schoolYear   String
    semester     Int
    module       String
    professor    String
    url          String
    uploadedAt   DateTime @default(now())

    uploadedBy      User   @relation(fields: [uploadedByEmail], references: [email])
    uploadedByEmail String
}
