# Copy to .env and fill in the values.

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/usthb_tresor?schema=public

# Auth.js — Google login provider
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google Drive (OAuth) — used to upload/serve contributed files
# Reuse an OAuth client, then mint a refresh token (e.g. via the OAuth Playground).
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_REFRESH_TOKEN=
